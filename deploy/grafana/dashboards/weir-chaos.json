{
  "uid": "weir-chaos",
  "title": "weir \u2014 chaos",
  "tags": [
    "weir",
    "weir-level"
  ],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "refresh": "10s",
  "links": [
    {
      "type": "dashboards",
      "title": "weir dashboards",
      "tags": [
        "weir"
      ],
      "asDropdown": true,
      "includeVars": false,
      "keepTime": true,
      "targetBlank": false,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Summary",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "type": "stat",
      "title": "Up",
      "description": "Is this instance being scraped.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 0
                },
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min(up{job=\"weir-chaos\"})"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Ingest rate",
      "description": "Records accepted/sec (all tiers).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "B",
          "expr": "sum(rate(weir_records_accepted_total{job=\"weir-chaos\"}[$__rate_interval]))"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Ack rate",
      "description": "Records acked durably/sec.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "C",
          "expr": "sum(rate(weir_records_ack_total{job=\"weir-chaos\"}[$__rate_interval]))"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Nack rate",
      "description": "Records Nacked/sec. Should be ~0.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 0.001
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "D",
          "expr": "sum(rate(weir_records_nack_total{job=\"weir-chaos\"}[$__rate_interval]))"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "fsync p99",
      "description": "Durable-tier fsync p99 \u2014 the fsync-bound latency signal.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "E",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 12,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Sink health",
      "description": "Active sink state (one-hot).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Healthy",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Degraded",
                  "color": "yellow",
                  "index": 1
                },
                "2": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 2
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "F",
          "expr": "sum(weir_sink_health{job=\"weir-chaos\", state=\"degraded\"}) + 2 * sum(weir_sink_health{job=\"weir-chaos\", state=\"down\"})"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 15,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Drain state",
      "description": "Active drain state (one-hot).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Draining",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "Retrying",
                  "color": "yellow",
                  "index": 1
                },
                "2": {
                  "text": "BLOCKED",
                  "color": "red",
                  "index": 2
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "G",
          "expr": "sum(weir_drain_state{job=\"weir-chaos\", state=\"retrying_transient\"}) + 2 * sum(weir_drain_state{job=\"weir-chaos\", state=\"blocked_dead_letter_full\"})"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 18,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Queue depth",
      "description": "Records waiting in the work queue.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "H",
          "expr": "max(weir_queue_depth{job=\"weir-chaos\"})"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 21,
        "y": 1
      }
    },
    {
      "type": "stat",
      "title": "Sink fwd",
      "description": "Is the configured sink forwarding? 1 = \"noop\" (records acked then DISCARDED, not delivered); 0 = a real sink is forwarding.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Forwarding",
                  "color": "green",
                  "index": 0
                },
                "1": {
                  "text": "NOOP \u26a0",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "I",
          "expr": "sum(weir_sink_info{job=\"weir-chaos\", sink_type=\"noop\"})"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 5
      }
    },
    {
      "type": "row",
      "title": "Latency percentiles",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      }
    },
    {
      "type": "timeseries",
      "title": "WAB fsync latency",
      "description": "fdatasync latency percentiles. weir is fsync-bound, so Sync-tier durability \u2248 this.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "J",
          "expr": "histogram_quantile(0.5,  sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "refId": "K",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))",
          "legendFormat": "p99"
        },
        {
          "refId": "L",
          "expr": "histogram_quantile(0.999, sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))",
          "legendFormat": "p99.9"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 10
      }
    },
    {
      "type": "heatmap",
      "title": "fsync latency distribution",
      "description": "Full fdatasync latency histogram over time \u2014 see the modes, not just percentiles.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "targets": [
        {
          "refId": "M",
          "expr": "sum(rate(weir_wab_fsync_duration_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "options": {
        "calculate": false,
        "color": {
          "mode": "scheme",
          "scheme": "Spectral",
          "steps": 64,
          "reverse": true
        },
        "yAxis": {
          "unit": "s",
          "axisPlacement": "left"
        },
        "cellGap": 1,
        "legend": {
          "show": true
        },
        "tooltip": {
          "show": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "scaleDistribution": {
              "type": "linear"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 10
      }
    },
    {
      "type": "timeseries",
      "title": "Accept + sink-commit latency (p50/p99)",
      "description": "Socket-accept latency and Sink::commit latency \u2014 the non-fsync ends of the pipeline.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "N",
          "expr": "histogram_quantile(0.5,  sum by (le) (rate(weir_accept_latency_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))",
          "legendFormat": "accept p50"
        },
        {
          "refId": "O",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_accept_latency_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))",
          "legendFormat": "accept p99"
        },
        {
          "refId": "P",
          "expr": "histogram_quantile(0.5,  sum by (le) (rate(weir_sink_commit_duration_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))",
          "legendFormat": "commit p50"
        },
        {
          "refId": "Q",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_sink_commit_duration_seconds_bucket{job=\"weir-chaos\"}[$__rate_interval])))",
          "legendFormat": "commit p99"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 18
      }
    },
    {
      "type": "row",
      "title": "Per-tier breakdown",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      }
    },
    {
      "type": "timeseries",
      "title": "Accepted/sec by tier",
      "description": "Ingest split by durability tier (Sync / Batched / Buffered).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "R",
          "expr": "sum by (tier) (rate(weir_records_accepted_total{job=\"weir-chaos\"}[$__rate_interval]))",
          "legendFormat": "{{tier}}"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 27
      }
    },
    {
      "type": "timeseries",
      "title": "Acked/sec by tier",
      "description": "Durable acks split by tier \u2014 compare against accepted to spot backpressure.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "S",
          "expr": "sum by (tier) (rate(weir_records_ack_total{job=\"weir-chaos\"}[$__rate_interval]))",
          "legendFormat": "{{tier}}"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 27
      }
    },
    {
      "type": "piechart",
      "title": "Tier share (cumulative)",
      "description": "Share of total accepted records by tier.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "pieType": "donut"
      },
      "targets": [
        {
          "refId": "T",
          "expr": "sum by (tier) (weir_records_accepted_total{job=\"weir-chaos\"})",
          "legendFormat": "{{tier}}"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 27
      }
    },
    {
      "type": "row",
      "title": "Segment lifecycle",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 34
      }
    },
    {
      "type": "timeseries",
      "title": "Segment transitions/sec by state",
      "description": "open \u2192 sealed \u2192 confirmed (\u2192 quarantined) transitions/sec \u2014 segment churn at this load.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "U",
          "expr": "sum by (state) (rate(weir_wab_segments_total{job=\"weir-chaos\"}[$__rate_interval]))",
          "legendFormat": "{{state}}"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 35
      }
    },
    {
      "type": "timeseries",
      "title": "WAB bytes on disk",
      "description": "Current bytes held in WAB segment files (buffered, not yet drained).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "V",
          "expr": "sum(weir_wab_bytes_on_disk{job=\"weir-chaos\"})",
          "legendFormat": "wab bytes"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 35
      }
    },
    {
      "type": "row",
      "title": "Sink & drain detail",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 42
      }
    },
    {
      "type": "timeseries",
      "title": "Sink outcome/sec (committed / retried / dead-lettered)",
      "description": "Drain delivery outcomes/sec. dead_lettered = permanently rejected \u2192 on disk.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "dead_lettered"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "W",
          "expr": "sum by (outcome) (rate(weir_sink_commit_records_total{job=\"weir-chaos\"}[$__rate_interval]))",
          "legendFormat": "{{outcome}}"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 43
      }
    },
    {
      "type": "state-timeline",
      "title": "Drain state over time",
      "description": "Exactly one active. blocked_dead_letter_full = all drain paused.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 80
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": " "
                },
                "1": {
                  "text": "active"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "transparent",
                "value": null
              },
              {
                "color": "blue",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "showValue": "never"
      },
      "targets": [
        {
          "refId": "X",
          "expr": "weir_drain_state{job=\"weir-chaos\"}",
          "legendFormat": "{{state}}"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 43
      }
    },
    {
      "type": "timeseries",
      "title": "Queue depth",
      "description": "Work-queue depth \u2014 climbs when ingest outruns the WAB flushers.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "Y",
          "expr": "weir_queue_depth{job=\"weir-chaos\"}",
          "legendFormat": "queue depth"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 50
      }
    },
    {
      "type": "timeseries",
      "title": "Dead-letter bytes on disk",
      "description": "Permanently-rejected records awaiting manual handling. Reaching the cap BLOCKS the drain.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "Z",
          "expr": "sum(weir_dead_letter_bytes_on_disk{job=\"weir-chaos\"})",
          "legendFormat": "dead-letter bytes"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 50
      }
    },
    {
      "type": "timeseries",
      "title": "Stranded vs resumed segments/sec",
      "description": "Segments stranded (transient retries exhausted) vs auto-resumed when the sink recovered (4a). Stranded climbing without matching resumed = delivery is stuck; correlate with sink health.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "stranded"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "[",
          "expr": "sum(rate(weir_drain_segments_stranded_total{job=\"weir-chaos\"}[$__rate_interval]))",
          "legendFormat": "stranded"
        },
        {
          "refId": "\\",
          "expr": "sum(rate(weir_drain_segments_resumed_total{job=\"weir-chaos\"}[$__rate_interval]))",
          "legendFormat": "resumed"
        }
      ],
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 57
      }
    }
  ]
}
