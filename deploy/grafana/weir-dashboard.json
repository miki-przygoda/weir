{
  "title": "weir — durable write buffer",
  "uid": "weir-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "tags": ["weir"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "job",
        "label": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(weir_wab_fsync_duration_seconds_count, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "Ingest", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },

    {
      "type": "timeseries",
      "title": "Ingest rate by tier",
      "description": "Records accepted per second, by durability tier.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (tier) (rate(weir_records_accepted_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "{{tier}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ack vs Nack rate",
      "description": "Acks should track accepts; nacks must stay at zero in healthy operation.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "nack" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(weir_records_ack_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "ack" },
        { "refId": "B", "expr": "sum(rate(weir_records_nack_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "nack" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Accept latency (p99)",
      "description": "Socket-accept-to-enqueue latency. Independent of the durability fsync.",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_accept_latency_seconds_bucket{job=~\"$job\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Queue depth",
      "description": "In-flight records between the socket layer and the workers. Sustained growth = downstream backpressure.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "expr": "weir_queue_depth{job=~\"$job\"}", "legendFormat": "depth" }
      ]
    },

    { "type": "row", "title": "Durability (WAB + fsync)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }, "collapsed": false },

    {
      "type": "heatmap",
      "title": "fsync duration distribution",
      "description": "The dominant durable-write latency signal. weir is fsync-bound; this is where time goes. NVMe baseline ~150µs, SATA SSD ~1.4ms.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Spectral", "mode": "scheme" }, "yAxis": { "unit": "s" } },
      "targets": [
        { "refId": "A", "expr": "sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "fsync latency (p99 / p99.9)",
      "description": "Durability SLO signal. Calibrate alert thresholds to your storage: NVMe p99.9 ~2.4ms, SATA SSD ~6ms (measured). Sustained climbs = storage pressure.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))", "legendFormat": "p99" },
        { "refId": "B", "expr": "histogram_quantile(0.999, sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))", "legendFormat": "p99.9" }
      ]
    },
    {
      "type": "stat",
      "title": "fsync failures",
      "description": "MUST be 0. A non-zero value is a P0 durability hazard — the WAB could not guarantee a record on stable storage. The producer is Nacked (no false ack — DST-verified), so investigate the disk/filesystem.",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_wab_fsync_failures_total{job=~\"$job\"})", "legendFormat": "failures" } ]
    },
    {
      "type": "stat",
      "title": "flusher panics",
      "description": "MUST be 0. A WAB flusher thread panicked. The supervisor respawns up to 10× then takes the shard offline (Nack-everything). P0.",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_wab_flusher_panics_total{job=~\"$job\"})", "legendFormat": "panics" } ]
    },
    {
      "type": "timeseries",
      "title": "fsync amortization (fsyncs per durable record)",
      "description": "Group-fsync efficiency: one fsync covers a whole batch. Approaches 1.0 under low concurrency (each record its own fsync); falls far below 1.0 as concurrent Sync/Batched producers coalesce (good — this is the WAB's durable-throughput lever). A rise toward 1.0 under load = batch collapse.",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(weir_wab_fsync_duration_seconds_count{job=~\"$job\"}[$__rate_interval])) / clamp_min(sum(rate(weir_records_accepted_total{job=~\"$job\", tier=~\"sync|batched\"}[$__rate_interval])), 0.001)", "legendFormat": "fsyncs / record" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Segment lifecycle (open → sealed → confirmed → quarantined)",
      "description": "Records moving through the WAB. open = created, sealed = rotated/shutdown, confirmed = drained to the sink. quarantined > 0 = corruption found on recovery (data-integrity alert).",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "none" } } }, "overrides": [ { "matcher": { "id": "byName", "options": "quarantined" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum by (state) (weir_wab_segments_total{job=~\"$job\"})", "legendFormat": "{{state}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "WAB bytes on disk",
      "description": "Un-drained segment bytes. Steady growth = the sink can't keep up with ingest (the WAB is doing its job buffering, but watch disk).",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(weir_wab_bytes_on_disk{job=~\"$job\"})", "legendFormat": "bytes" } ]
    },

    { "type": "row", "title": "Drain (sink delivery)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }, "collapsed": false },

    {
      "type": "state-timeline",
      "title": "Drain state",
      "description": "Exactly one is 1 at a time. blocked_dead_letter_full = all drain paused (high severity); retrying_transient = sink erroring/slow.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80 }, "mappings": [ { "type": "value", "options": { "0": { "text": " " }, "1": { "text": "active" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "transparent", "value": null }, { "color": "blue", "value": 1 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "showValue": "never" },
      "targets": [ { "refId": "A", "expr": "weir_drain_state{job=~\"$job\"}", "legendFormat": "{{state}}" } ]
    },
    {
      "type": "timeseries",
      "title": "Sink outcome rate (committed / retried / dead-lettered)",
      "description": "committed = delivered. retried = transient error (will retry). dead_lettered = permanently rejected → on disk for manual handling.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "dead_lettered" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (outcome) (rate(weir_sink_commit_records_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "{{outcome}}" } ]
    },
    {
      "type": "stat",
      "title": "Sink health",
      "description": "1 = healthy, 0 = unhealthy (sink reporting itself down).",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [ { "type": "value", "options": { "1": { "text": "healthy", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "none", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "min(weir_sink_health{job=~\"$job\"})", "legendFormat": "health" } ]
    },
    {
      "type": "timeseries",
      "title": "Dead-letter bytes on disk",
      "description": "Permanently-rejected records awaiting manual handling. Reaching the cap blocks the drain entirely.",
      "gridPos": { "h": 5, "w": 18, "x": 6, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(weir_dead_letter_bytes_on_disk{job=~\"$job\"})", "legendFormat": "dead-letter bytes" } ]
    },

    { "type": "row", "title": "System health", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 }, "collapsed": false },

    {
      "type": "timeseries",
      "title": "Connection rejections (peer-UID)",
      "description": "Connections rejected by the SO_PEERCRED uid check. A spike may indicate a misconfigured producer or an unauthorized client.",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(weir_connection_rejected_peer_uid_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "peer-uid rejects" } ]
    },
    {
      "type": "timeseries",
      "title": "TLS handshake failures / cert reloads",
      "description": "(tls feature) Handshake failures = client-cert/CA problems. Reloads should succeed on SIGHUP; a failed reload keeps the old config.",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(weir_tls_handshake_failures_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "handshake failures/s" },
        { "refId": "B", "expr": "sum(increase(weir_tls_config_reloads_total{job=~\"$job\"}[$__range]))", "legendFormat": "reloads (range)" }
      ]
    },
    {
      "type": "stat",
      "title": "Ack timeouts",
      "description": "Records whose ack never fired within the timeout — a wedged flusher signature. Should be 0.",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 50 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_ack_timeout_total{job=~\"$job\"})", "legendFormat": "ack timeouts" } ]
    }
  ]
}
