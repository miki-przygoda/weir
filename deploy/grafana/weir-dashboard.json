{
  "title": "weir — durable write buffer",
  "uid": "weir-overview",
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "tags": ["weir"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "job",
        "label": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(weir_wab_fsync_duration_seconds_count, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "type": "row", "title": "Overview — at a glance", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "collapsed": false },

    {
      "type": "stat", "title": "Instance",
      "description": "Is weir being scraped (up).",
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "1": { "text": "UP", "color": "green", "index": 0 }, "0": { "text": "DOWN", "color": "red", "index": 1 } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "none", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "min(up{job=~\"$job\"})" } ]
    },
    {
      "type": "stat", "title": "fsync failures",
      "description": "MUST be 0. Non-zero = durability hazard (P0). Producer was Nacked — no false ack (DST-verified).",
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_wab_fsync_failures_total{job=~\"$job\"})" } ]
    },
    {
      "type": "stat", "title": "flusher panics",
      "description": "MUST be 0. A flusher thread panicked (P0).",
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_wab_flusher_panics_total{job=~\"$job\"})" } ]
    },
    {
      "type": "stat", "title": "ack timeouts",
      "description": "Wedged-flusher signature. Should be 0.",
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_ack_timeout_total{job=~\"$job\"})" } ]
    },
    {
      "type": "stat", "title": "Sink health",
      "description": "Active sink state (one-hot). Healthy = delivering; Down = stalled (WAB keeps buffering durably).",
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "Healthy", "color": "green", "index": 0 }, "1": { "text": "Degraded", "color": "yellow", "index": 1 }, "2": { "text": "DOWN", "color": "red", "index": 2 } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "none", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_sink_health{job=~\"$job\", state=\"degraded\"}) + 2 * sum(weir_sink_health{job=~\"$job\", state=\"down\"})" } ]
    },
    {
      "type": "stat", "title": "Drain state",
      "description": "Active drain state (one-hot). Draining = healthy; Blocked = dead-letter full (all delivery paused).",
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": { "text": "Draining", "color": "green", "index": 0 }, "1": { "text": "Retrying", "color": "yellow", "index": 1 }, "2": { "text": "BLOCKED", "color": "red", "index": 2 } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 2 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "none", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(weir_drain_state{job=~\"$job\", state=\"retrying_transient\"}) + 2 * sum(weir_drain_state{job=~\"$job\", state=\"blocked_dead_letter_full\"})" } ]
    },
    {
      "type": "stat", "title": "Ingest rate",
      "description": "Records accepted per second (all tiers).",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(rate(weir_records_accepted_total{job=~\"$job\"}[$__rate_interval]))" } ]
    },
    {
      "type": "stat", "title": "Nack rate",
      "description": "Records Nacked per second. Should be ~0.",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] }, "color": { "mode": "thresholds" } }, "overrides": [] },
      "options": { "graphMode": "area", "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "refId": "A", "expr": "sum(rate(weir_records_nack_total{job=~\"$job\"}[$__rate_interval]))" } ]
    },

    { "type": "row", "title": "Ingest", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "collapsed": false },

    {
      "type": "timeseries", "title": "Ingest rate by tier",
      "description": "Records accepted per second, by durability tier.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (tier) (rate(weir_records_accepted_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "{{tier}}" } ]
    },
    {
      "type": "timeseries", "title": "Ack vs Nack rate",
      "description": "Acks track accepts; nacks must stay at zero in healthy operation.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "nack" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(weir_records_ack_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "ack" },
        { "refId": "B", "expr": "sum(rate(weir_records_nack_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "nack" }
      ]
    },
    {
      "type": "timeseries", "title": "Accept latency (p99)",
      "description": "Socket-accept → enqueue latency. Independent of the durability fsync.",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_accept_latency_seconds_bucket{job=~\"$job\"}[$__rate_interval])))", "legendFormat": "p99" } ]
    },
    {
      "type": "timeseries", "title": "Queue depth",
      "description": "In-flight records between the socket layer and the workers. Sustained growth = downstream backpressure.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "weir_queue_depth{job=~\"$job\"}", "legendFormat": "depth" } ]
    },

    { "type": "row", "title": "Durability (WAB + fsync) — weir is fsync-bound", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 }, "collapsed": false },

    {
      "type": "heatmap", "title": "fsync duration distribution",
      "description": "The dominant durable-write latency signal. NVMe baseline ~150µs, SATA SSD ~1.4ms.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": { "calculate": false, "cellGap": 1, "color": { "scheme": "Spectral", "mode": "scheme" }, "yAxis": { "unit": "s" } },
      "targets": [ { "refId": "A", "expr": "sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval]))", "format": "heatmap", "legendFormat": "{{le}}" } ]
    },
    {
      "type": "timeseries", "title": "fsync latency (p99 / p99.9)",
      "description": "Durability SLO signal. Measured baselines: NVMe p99.9 ~2.4ms, SATA SSD ~6ms. Sustained climbs = storage pressure.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.99, sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))", "legendFormat": "p99" },
        { "refId": "B", "expr": "histogram_quantile(0.999, sum by (le) (rate(weir_wab_fsync_duration_seconds_bucket{job=~\"$job\"}[$__rate_interval])))", "legendFormat": "p99.9" }
      ]
    },
    {
      "type": "timeseries", "title": "fsync amortization (fsyncs per durable record)",
      "description": "Group-fsync efficiency: one fsync covers a whole batch. Far below 1.0 = concurrent Sync/Batched records coalescing (good — the durable-throughput lever). A rise toward 1.0 under load = batch collapse.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(weir_wab_fsync_duration_seconds_count{job=~\"$job\"}[$__rate_interval])) / clamp_min(sum(rate(weir_records_accepted_total{job=~\"$job\", tier=~\"sync|batched\"}[$__rate_interval])), 0.001)", "legendFormat": "fsyncs / record" } ]
    },
    {
      "type": "timeseries", "title": "Segment lifecycle (open → sealed → confirmed → quarantined)",
      "description": "Records moving through the WAB. open = created, sealed = rotated, confirmed = drained to sink. quarantined > 0 = corruption found on recovery.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "quarantined" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (state) (weir_wab_segments_total{job=~\"$job\"})", "legendFormat": "{{state}}" } ]
    },
    {
      "type": "timeseries", "title": "WAB bytes on disk",
      "description": "Un-drained segment bytes. Steady growth = the sink can't keep up with ingest.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(weir_wab_bytes_on_disk{job=~\"$job\"})", "legendFormat": "bytes" } ]
    },

    { "type": "row", "title": "Drain (sink delivery)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 }, "collapsed": false },

    {
      "type": "state-timeline", "title": "Drain state over time",
      "description": "Exactly one is active. blocked_dead_letter_full = all drain paused; retrying_transient = sink erroring/slow.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80 }, "mappings": [ { "type": "value", "options": { "0": { "text": " " }, "1": { "text": "active" } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "transparent", "value": null }, { "color": "blue", "value": 1 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "showValue": "never" },
      "targets": [ { "refId": "A", "expr": "weir_drain_state{job=~\"$job\"}", "legendFormat": "{{state}}" } ]
    },
    {
      "type": "timeseries", "title": "Sink outcome rate (committed / retried / dead-lettered)",
      "description": "committed = delivered. retried = transient error. dead_lettered = permanently rejected → on disk for manual handling.",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [ { "matcher": { "id": "byName", "options": "dead_lettered" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (outcome) (rate(weir_sink_commit_records_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "{{outcome}}" } ]
    },
    {
      "type": "timeseries", "title": "Dead-letter bytes on disk",
      "description": "Permanently-rejected records awaiting manual handling. Reaching the cap blocks the drain entirely.",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(weir_dead_letter_bytes_on_disk{job=~\"$job\"})", "legendFormat": "dead-letter bytes" } ]
    },

    { "type": "row", "title": "System health", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 }, "collapsed": false },

    {
      "type": "timeseries", "title": "Connection rejections (peer-UID)",
      "description": "Connections rejected by the SO_PEERCRED uid check — a misconfigured or unauthorized client.",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(weir_connection_rejected_peer_uid_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "peer-uid rejects" } ]
    },
    {
      "type": "timeseries", "title": "TLS handshake failures / cert reloads",
      "description": "(tls feature) Handshake failures = client-cert/CA problems. Reloads should succeed on SIGHUP.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(weir_tls_handshake_failures_total{job=~\"$job\"}[$__rate_interval]))", "legendFormat": "handshake failures/s" },
        { "refId": "B", "expr": "sum(increase(weir_tls_config_reloads_total{job=~\"$job\"}[$__range]))", "legendFormat": "reloads (range)" }
      ]
    }
  ]
}
